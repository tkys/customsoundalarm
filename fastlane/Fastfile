default_platform(:ios)

platform :ios do
  # API Key は環境変数またはファイルから読み込み
  # ASC_KEY_ID, ASC_ISSUER_ID, ASC_KEY_FILEPATH を設定すること
  def api_key
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_FILEPATH"] || "#{ENV['HOME']}/Downloads/AuthKey_#{ENV['ASC_KEY_ID']}.p8",
      duration: 1200,
      in_house: false
    )
  end

  desc "メタデータのみアップロード（スクリーンショットなし）"
  lane :upload_metadata do
    deliver(
      api_key: api_key,
      app_identifier: "com.tkysdev.customsoundalarm",
      metadata_path: "./fastlane/metadata",
      skip_binary_upload: true,
      skip_screenshots: true,
      force: true,
      run_precheck_before_submit: false,
      submit_for_review: false,
      primary_category: "UTILITIES",
      app_version: "1.0.0",
      languages: ["en-US", "ja"]
    )
  end

  desc "メタデータ + スクリーンショットをアップロード"
  lane :upload_all do
    deliver(
      api_key: api_key,
      app_identifier: "com.tkysdev.customsoundalarm",
      metadata_path: "./fastlane/metadata",
      screenshots_path: "./fastlane/screenshots",
      skip_binary_upload: true,
      skip_screenshots: false,
      force: true,
      run_precheck_before_submit: false,
      submit_for_review: false,
      primary_category: "UTILITIES",
      app_version: "1.0.0",
      languages: ["en-US", "ja"]
    )
  end

  desc "ビルド番号をインクリメント"
  lane :bump do |options|
    # project.yml の CURRENT_PROJECT_VERSION を更新
    version = options[:build] || "2"
    sh("cd .. && sed -i '' 's/CURRENT_PROJECT_VERSION: .*/CURRENT_PROJECT_VERSION: \"#{version}\"/' project.yml")
    sh("cd .. && xcodegen generate")
    UI.success("Build number updated to #{version}")
  end
end
