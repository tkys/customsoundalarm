default_platform(:ios)

platform :ios do
  def api_key
    app_store_connect_api_key(
      key_id: "HQ762J84KW",
      issuer_id: "f4fe1f90-e544-4676-afe7-207553e56612",
      key_filepath: "#{ENV['HOME']}/Downloads/AuthKey_HQ762J84KW.p8",
      duration: 1200,
      in_house: false
    )
  end

  desc "メタデータのみアップロード（スクリーンショットなし）"
  lane :upload_metadata do
    deliver(
      api_key: api_key,
      app_identifier: "com.tkysdev.customsoundalarm",
      metadata_path: "./fastlane/metadata",
      skip_binary_upload: true,
      skip_screenshots: true,
      force: true,
      run_precheck_before_submit: false,
      submit_for_review: false,
      primary_category: "UTILITIES",
      app_version: "1.1.0",
      languages: ["en-US", "ja"]
    )
  end

  desc "メタデータ + スクリーンショットをアップロード"
  lane :upload_all do
    deliver(
      api_key: api_key,
      app_identifier: "com.tkysdev.customsoundalarm",
      metadata_path: "./fastlane/metadata",
      screenshots_path: "./fastlane/screenshots",
      skip_binary_upload: true,
      skip_screenshots: false,
      force: true,
      run_precheck_before_submit: false,
      submit_for_review: false,
      primary_category: "UTILITIES",
      app_version: "1.1.0",
      languages: ["en-US", "ja"]
    )
  end

  desc "リリースビルドを作成し App Store Connect にアップロード＆審査提出（v1.1.0）"
  lane :release do
    build_app(
      scheme: "CustomSoundAlarm",
      configuration: "Release",
      output_directory: "./build",
      output_name: "CustomSoundAlarm.ipa",
      clean: false,
      export_method: "app-store",
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: "F8ZP855SM2",
        signingCertificate: "Apple Distribution",
        provisioningProfiles: {
          "com.tkysdev.customsoundalarm" => "com.tkysdev.customsoundalarm AppStore",
          "com.tkysdev.customsoundalarm.widget" => "com.tkysdev.customsoundalarm.widget AppStore",
          "com.tkysdev.customsoundalarm.share" => "com.tkysdev.customsoundalarm.share AppStore"
        }
      }
    )
    upload_to_app_store(
      api_key: api_key,
      app_identifier: "com.tkysdev.customsoundalarm",
      metadata_path: "./fastlane/metadata",
      skip_screenshots: true,
      skip_metadata: false,
      force: true,
      run_precheck_before_submit: false,
      submit_for_review: true,
      automatic_release: false,
      submission_information: {
        add_id_info_uses_idfa: false
      },
      app_version: "1.1.0",
      languages: ["en-US", "ja"]
    )
  end

  desc "ビルド番号をインクリメント"
  lane :bump do |options|
    version = options[:build] || "2"
    sh("cd .. && sed -i '' 's/CURRENT_PROJECT_VERSION: .*/CURRENT_PROJECT_VERSION: \"#{version}\"/' project.yml")
    sh("cd .. && xcodegen generate")
    UI.success("Build number updated to #{version}")
  end
end
