//
//  Secrets.xcconfig.example
//
//  Template for PostHog credentials. Copy this file to `Secrets.xcconfig`
//  (gitignored) and fill in real values.
//
//  PostHog Project API Key is write-only and safe to embed in client apps,
//  but we keep it out of the repo to allow per-environment overrides.
//
//  Steps:
//    1. cp Secrets.xcconfig.example Secrets.xcconfig
//    2. Replace placeholder values below
//    3. `Secrets.xcconfig` is gitignored — never commit it
//

POSTHOG_API_KEY = phc_YOUR_PROJECT_API_KEY
// xcconfig treats // as a line comment, so split the URL scheme with an empty $() expansion
POSTHOG_HOST = https:/$()/us.i.posthog.com
POSTHOG_DEBUG = NO
